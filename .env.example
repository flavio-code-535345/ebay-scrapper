# eBay Deal Finder — Environment Variables
# Copy this file to ".env" and fill in your values.
# NEVER commit ".env" (it is already listed in .gitignore).

# ── eBay Official API ────────────────────────────────────────────────────────
# Register at https://developer.ebay.com/ to obtain credentials.
# Both Client ID and Client Secret are required for the Browse API.
# Leave blank to fall back to HTML scraping.
#
# EBAY_CLIENT_ID     — Application Client ID (App ID) from your eBay developer account.
# EBAY_CLIENT_SECRET — Application Client Secret (Cert ID) from your eBay developer account.
# EBAY_MARKETPLACE_ID — eBay marketplace to search (default: EBAY_DE for Germany).
#                       Other values: EBAY_US, EBAY_GB, EBAY_FR, EBAY_IT, EBAY_ES, etc.
# EBAY_ENVIRONMENT   — "production" (default) or "sandbox" for eBay's sandbox environment.
# DATA_SOURCE        — Which data engine to use:
#                       "auto"    (default) – Use official API when credentials are present,
#                                             otherwise fall back to HTML scraping.
#                       "api"     – Always use the official eBay Browse API (requires creds).
#                       "scraper" – Always use legacy HTML scraping.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_DE
EBAY_ENVIRONMENT=production
DATA_SOURCE=auto

# ── Google Gemini AI ────────────────────────────────────────────────────────
# Obtain a key at https://aistudio.google.com/app/apikey
# When set, each deal is analysed by Gemini (multimodal text + images).
# Leave blank to disable AI assessment and rely on the rules engine only.
GEMINI_API_KEY=

# ── Flask / App ─────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=/data/ebay_deals.db

# ── Reseller / Flipper Strategies ────────────────────────────────────────────
# MIN_MARGIN_PCT — Minimum profit-margin % vs sold prices to flag a deal
#                 as "below_sold_price". Default: 15
MIN_MARGIN_PCT=15

# HIGH_WATCHER_THRESHOLD — Minimum watch_count to consider a deal a
#                          high-watcher opportunity. Default: 20
HIGH_WATCHER_THRESHOLD=20

# HIDDEN_GEM_DETECTION — Set to "true" to ask Gemini to flag items with poor
#                        photos as potential hidden gems. Default: false
HIDDEN_GEM_DETECTION=false
