# eBay Deal Finder — Environment Variables
# Copy this file to ".env" and fill in your values.
# NEVER commit ".env" (it is already listed in .gitignore).

# ── Google Gemini AI ────────────────────────────────────────────────────────
# Obtain a key at https://aistudio.google.com/app/apikey
# When set, each deal is analysed by Gemini (multimodal text + images).
# Leave blank to disable AI assessment and rely on the rules engine only.
GEMINI_API_KEY=

# ── Flask / App ─────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=/data/ebay_deals.db
